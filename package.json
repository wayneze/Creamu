{
  "name": "creamu",
  "version": "0.1.0",
  "private": true,
  "description": "Creamu — userscript monorepo",
  "repository": {
    "type": "git",
    "url": "https://github.com/wayneze/Creamu.git"
  },
  "author": "wayneze",
  "type": "module",
  "scripts": {
    "build": "npm run build -w @creamu/exh-commander && npm run build -w @creamu/jlc-commander && npm run build -w @creamu/scout-commander",
    "build:exh": "npm run build -w @creamu/exh-commander",
    "build:jlc": "npm run build -w @creamu/jlc-commander",
    "build:scout": "npm run build -w @creamu/scout-commander",
    "check:repo": "node scripts/check-repository.mjs",
    "check:metadata": "node scripts/check-metadata.mjs",
    "check:dist": "node scripts/check-dist.mjs",
    "test": "node scripts/test.mjs",
    "test:e2e": "node scripts/test-e2e.mjs",
    "check": "npm run check:repo && npm test"
  },
  "devDependencies": {
    "jquery": "3.7.1",
    "playwright": "1.61.1"
  },
  "workspaces": [
    "packages/exh-commander",
    "packages/jlc-commander",
    "packages/scout-commander"
  ]
}
